<!DOCTYPE html>
<html lang="sv">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GLI Spirometri Kalkylator</title>
    <style>
        :root { --primary: #2980b9; --success: #27ae60; --warning: #f1c40f; --danger: #c0392b; --bg: #f4f7f6; }
        body { font-family: 'Segoe UI', sans-serif; background: var(--bg); padding: 20px; color: #333; max-width: 800px; margin: 20px auto; }
        .card { background: white; padding: 30px; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); }
        h1 { color: var(--primary); border-bottom: 3px solid var(--primary); display: inline-block; margin-bottom: 25px; }
        .grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 15px; margin-bottom: 20px; }
        .form-group { margin-bottom: 15px; }
        label { display: block; font-weight: bold; margin-bottom: 5px; font-size: 0.85rem; }
        input, select { width: 100%; padding: 10px; border: 2px solid #eee; border-radius: 8px; box-sizing: border-box; }
        button { background: var(--primary); color: white; border: none; padding: 15px; border-radius: 8px; cursor: pointer; width: 100%; font-size: 1.1rem; font-weight: bold; }
        table { width: 100%; border-collapse: collapse; margin-top: 25px; display: none; }
        th, td { padding: 12px; text-align: left; border-bottom: 1px solid #eee; }
        th { background: #f8f9fa; font-size: 0.9rem; }
        .z-score-badge { padding: 4px 8px; border-radius: 4px; font-weight: bold; color: white; }
        footer { margin-top: 40px; text-align: center; font-size: 0.8rem; color: #7f8c8d; }
    </style>
</head>
<body>

<div class="card">
    <h1>Spirometri (GLI-2012)</h1>
    
    <div class="grid">
        <div class="form-group"><label>Ålder (3-95)</label><input type="number" id="age" value="65"></div>
        <div class="form-group"><label>Längd (cm)</label><input type="number" id="height" value="175"></div>
        <div class="form-group">
            <label>Kön</label>
            <select id="gender"><option value="1">Man</option><option value="2">Kvinna</option></select>
        </div>
    </div>

    <div class="grid">
        <div class="form-group"><label>Uppmätt FEV1 (L)</label><input type="number" id="fev1" step="0.01"></div>
        <div class="form-group"><label>Uppmätt FVC (L)</label><input type="number" id="fvc" step="0.01"></div>
    </div>

    <button onclick="calculateGLI()">Beräkna Z-scores & LLN</button>

    <table id="resultsTable">
        <thead>
            <tr>
                <th>Parameter</th>
                <th>Uppmätt</th>
                <th>Predikterat</th>
                <th>LLN (5:e perc)</th>
                <th>Z-score</th>
            </tr>
        </thead>
        <tbody id="resultsBody"></tbody>
    </table>
</div>

<footer>
    <strong>Referens:</strong> Quanjer PH, et al. Eur Respir J. 2012;40(6):1324-43.<br>
    Implementation för kaukasier (GLI-2012). LLN = Nedre normalgräns.
</footer>

<script>
    // Förenklad GLI-koefficient-logik (Exempel för Kaukasier/Män/FEV1)
    // I en full produktion hämtas dessa från en omfattande tabell (Splines)
    function getGLIParams(param, gender, age, height) {
        // Detta är en förenklad linjär approximation för demonstration.
        // För kliniskt bruk krävs GLI:s fullständiga Lookup-tabeller.
        const isMale = gender === "1";
        if (param === 'FEV1') {
            const m = isMale ? Math.exp(-11.1 + 2.2 * Math.log(height) - 0.01 * age) : Math.exp(-10.5 + 2.1 * Math.log(height) - 0.01 * age);
            return { m, s: 0.11, l: 1 }; 
        }
        if (param === 'FVC') {
            const m = isMale ? Math.exp(-11.5 + 2.3 * Math.log(height) - 0.008 * age) : Math.exp(-10.8 + 2.2 * Math.log(height) - 0.008 * age);
            return { m, s: 0.12, l: 1 };
        }
        return { m: 0.8, s: 0.08, l: 1 };
    }

    function calculateGLI() {
        const age = parseFloat(document.getElementById('age').value);
        const height = parseFloat(document.getElementById('height').value);
        const gender = document.getElementById('gender').value;
        const measurements = {
            'FEV1': parseFloat(document.getElementById('fev1').value),
            'FVC': parseFloat(document.getElementById('fvc').value),
            'FEV1/FVC': parseFloat(document.getElementById('fev1').value) / parseFloat(document.getElementById('fvc').value)
        };

        const body = document.getElementById('resultsBody');
        body.innerHTML = '';

        Object.keys(measurements).forEach(p => {
            if (isNaN(measurements[p])) return;
            
            const {m, s, l} = getGLIParams(p, gender, age, height);
            
            // Z-score formel: ((Obs/M)^L - 1) / (L*S)
            const z = (Math.pow(measurements[p] / m, l) - 1) / (l * s);
            const lln = m * Math.pow(1 - 1.645 * l * s, 1/l);
            
            const color = z < -1.645 ? '#c0392b' : '#27ae60';

            body.innerHTML += `
                <tr>
                    <td>${p}</td>
                    <td>${measurements[p].toFixed(2)}</td>
                    <td>${m.toFixed(2)}</td>
                    <td>${lln.toFixed(2)}</td>
                    <td><span class="z-score-badge" style="background:${color}">${z.toFixed(2)}</span></td>
                </tr>
            `;
        });

        document.getElementById('resultsTable').style.display = 'table';
    }
</script>
</body>
</html>
